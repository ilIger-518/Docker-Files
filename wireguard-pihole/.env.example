# Copy this file to .env and fill in the values before running docker compose up.

# Public IP address or domain name of the server.
# Clients use this to reach the WireGuard endpoint.
SERVER_URL=your.server.ip.or.domain

# UDP port WireGuard listens on (must be open in your firewall / security group).
SERVER_PORT=51820

# Pi-hole admin web interface password.
PIHOLE_PASSWORD=changeme_use_a_strong_password

# Timezone used by both containers (e.g. Europe/Berlin, America/New_York).
TIMEZONE=UTC

# Comma-separated list of peer names created automatically on first startup.
# Each name gets a config file and QR code under config/wireguard/peer_<name>/.
# Use add-client.sh to add more peers later without restarting the stack.
INITIAL_PEERS=phone
